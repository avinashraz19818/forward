#!/bin/bash

# SIMPLIFIED BOT MANAGER
# Usage: ./start [start|stop|restart|status|logs]

SCRIPT_NAME="forward.py"
LOG_DIR="logs"
PID_FILE="bot.pid"
VENV_DIR=".venv"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Banner
print_banner() {
    clear
    echo -e "${CYAN}"
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║   🚀 TELEGRAM FORWARDER BOT - MANAGER                   ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

# Check if bot is running
check_running() {
    if [ -f "$PID_FILE" ]; then
        OLD_PID=$(cat "$PID_FILE" 2>/dev/null)
        if [ ! -z "$OLD_PID" ] && ps -p "$OLD_PID" > /dev/null 2>&1; then
            return 0
        else
            rm -f "$PID_FILE" 2>/dev/null
            return 1
        fi
    fi
    return 1
}

ensure_venv() {
    if [ -d "$VENV_DIR" ]; then
        if [ ! -x "$VENV_DIR/bin/python3" ] || ! "$VENV_DIR/bin/python3" --version >/dev/null 2>&1; then
            BROKEN_VENV="${VENV_DIR}_broken_$(date +%s)"
            echo -e "${YELLOW}⚠️  Existing virtual environment is broken, backing up to $BROKEN_VENV${NC}"
            mv "$VENV_DIR" "$BROKEN_VENV"
        fi
    fi

    if [ ! -d "$VENV_DIR" ]; then
        echo -e "${YELLOW}🛠️  Creating virtual environment...${NC}"
        python3 -m venv "$VENV_DIR" || exit 1
    fi

    if [ -f "$VENV_DIR/bin/activate" ]; then
        . "$VENV_DIR/bin/activate"
        echo -e "${GREEN}✅ Virtual environment activated${NC}"
    fi

    if [ -f "requirements.txt" ]; then
        echo -e "${YELLOW}📦 Installing requirements...${NC}"
        "$VENV_DIR/bin/pip" install --upgrade pip >/dev/null 2>&1 || true
        "$VENV_DIR/bin/pip" install -r requirements.txt >/dev/null 2>&1 || true
    fi
}

# Stop bot
stop_bot() {
    echo -e "${YELLOW}🛑 Stopping bot...${NC}"

    if [ -f "$PID_FILE" ]; then
        OLD_PID=$(cat "$PID_FILE" 2>/dev/null)

        if [ ! -z "$OLD_PID" ] && ps -p "$OLD_PID" > /dev/null 2>&1; then
            kill "$OLD_PID" 2>/dev/null || true
            for i in {1..5}; do
                if ! ps -p "$OLD_PID" > /dev/null 2>&1; then
                    break
                fi
                sleep 1
            done
            if ps -p "$OLD_PID" > /dev/null 2>&1; then
                kill -9 "$OLD_PID" 2>/dev/null || true
                sleep 1
            fi
        fi
        rm -f "$PID_FILE" 2>/dev/null
    fi

    BOT_PROCESSES=$(ps aux | grep -E ".*${VENV_DIR}/bin/python3.*$SCRIPT_NAME|python.*$SCRIPT_NAME" | grep -v grep | awk '{print $2}' 2>/dev/null)
    if [ ! -z "$BOT_PROCESSES" ]; then
        echo "$BOT_PROCESSES" | xargs kill -9 2>/dev/null || true
        sleep 2
    fi
}

# Start bot
start_bot() {
    echo -e "${YELLOW}🚀 Starting bot...${NC}"

    if check_running; then
        stop_bot
        sleep 2
    fi

    if [ ! -f "$SCRIPT_NAME" ]; then
        echo -e "${RED}❌ Bot script not found: $SCRIPT_NAME${NC}"
        exit 1
    fi

    mkdir -p "$LOG_DIR" 2>/dev/null
    ensure_venv

    TIMESTAMP=$(date +%Y%m%d_%H%M%S)
    LOG_FILE="$LOG_DIR/bot_$TIMESTAMP.log"

    echo -e "${YELLOW}🔄 Starting bot process...${NC}"
    nohup "$VENV_DIR/bin/python3" -u "$SCRIPT_NAME" > "$LOG_FILE" 2>&1 &
    BOT_PID=$!

    echo "$BOT_PID" > "$PID_FILE"
    sleep 5

    if ps -p "$BOT_PID" > /dev/null 2>&1; then
        for i in {1..5}; do
            if ! ps -p "$BOT_PID" > /dev/null 2>&1; then
                if [ -f "$LOG_FILE" ]; then
                    tail -30 "$LOG_FILE"
                fi
                rm -f "$PID_FILE"
                return 1
            fi
            sleep 1
        done
    else
        if [ -f "$LOG_FILE" ]; then
            tail -30 "$LOG_FILE"
        fi
        rm -f "$PID_FILE"
        return 1
    fi

    return 0
}

show_status() {
    if check_running; then
        OLD_PID=$(cat "$PID_FILE" 2>/dev/null)
        echo "RUNNING $OLD_PID"
    else
        echo "STOPPED"
        return 1
    fi
}

show_logs() {
    LOG_FILE=$(ls -t "$LOG_DIR"/*.log 2>/dev/null | head -1)
    if [ -f "$LOG_FILE" ]; then
        tail -f "$LOG_FILE"
    else
        echo "No log files found"
    fi
}

main() {
    cd "$(dirname "$0")"
    ACTION=${1:-"start"}

    case $ACTION in
        "start")
            start_bot
            ;;
        "stop")
            stop_bot
            ;;
        "restart")
            stop_bot
            sleep 2
            start_bot
            ;;
        "status")
            show_status
            ;;
        "logs")
            show_logs
            ;;
        *)
            echo "Usage: ./start [start|stop|restart|status|logs]"
            exit 1
            ;;
    esac
}

main "$@"
